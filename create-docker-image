#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

IMAGE_NAME="${IMAGE_NAME:-parkiroid-web}"
IMAGE_TAG="${IMAGE_TAG:-$(grep -m1 '"version"' package.json | sed -E 's/.*"version"[[:space:]]*:[[:space:]]*"([^"]+)".*/\1/')}"
FULL_IMAGE="${IMAGE_NAME}:${IMAGE_TAG}"
OUTPUT_FILE="${OUTPUT_FILE:-${IMAGE_NAME}-${IMAGE_TAG}.tar}"

if [[ -f .env ]]; then
  set -a
  # shellcheck disable=SC1091
  source .env
  set +a
fi

VITE_API_BASE_URL="${VITE_API_BASE_URL:-http://localhost:8080/dogan/api/v1}"

echo "Building ${FULL_IMAGE} (VITE_API_BASE_URL=${VITE_API_BASE_URL})..."
docker build \
  --build-arg "VITE_API_BASE_URL=${VITE_API_BASE_URL}" \
  -t "${FULL_IMAGE}" \
  .

echo "Exporting image to ${OUTPUT_FILE}..."
docker save -o "${OUTPUT_FILE}" "${FULL_IMAGE}"

echo "Done: ${OUTPUT_FILE}"
